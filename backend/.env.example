# Copie ce fichier en .env et adapte.

NODE_ENV=development
PORT=3000

# CORS : origin exact (pas de wildcard en prod)
CORS_ORIGIN=http://localhost:5173

# --- Scraper ---

# Mode : mock | live | hybrid
# - mock   : pas de réseau, générateur procédural uniquement
# - live   : scraping réel, échec si la source bloque
# - hybrid : scraping réel avec fallback automatique sur le générateur
SCRAPER_MODE=live

# Moteur de fetch : fetch | browser
# - fetch   : undici + headers Chrome + cookies. Léger (~0 MB), ne passe PAS les
#             protections anti-bot avancées (DataDome, Cloudflare Turnstile...).
# - browser : Playwright Chromium. Passe la majorité des challenges JS, mais
#             nécessite `npm install playwright && npx playwright install chromium`
#             (~200 MB). Activer seulement si tu as besoin.
SCRAPER_ENGINE=auto

# Warm-up : visite la home page d'une source avant sa première recherche pour
# récupérer les cookies (cf_clearance, session, RGPD...). Recommandé.
SCRAPER_WARMUP=true

# Concurrence max par source (requêtes en parallèle)
SCRAPER_CONCURRENCY=2

# Timeout HTTP pour les requêtes scraping (ms)
HTTP_TIMEOUT=12000

# User-agent custom (sinon : pool Chrome réaliste).
# Pour du scraping honnête avec contact email (à utiliser quand la source tolère) :
# SCRAPER_USER_AGENT=FindMyCar/0.2 (+contact@findmycar.example)

# Rate limit API (req/min par IP)
RATE_LIMIT_MAX=120

# Cache
CACHE_TTL_SECONDS=600

# --- Firebase (persistance + stats) ---

# En local : chemin vers un service account JSON (console Firebase → Paramètres → Comptes de service).
# FIREBASE_SERVICE_ACCOUNT=/path/to/findmycar-service-account.json

# ID du projet Firebase (sinon auto-détecté depuis ADC sur Cloud Run)
# FIREBASE_PROJECT_ID=findmycar-prod

# --- Scheduled scraping ---

# Secret partagé avec Cloud Scheduler. Laisse vide en local (le endpoint renverra 503).
# SCHEDULER_SECRET=long-random-value
